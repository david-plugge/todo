{
	"name": "todo",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24",
			"onFail": "error"
		},
		"packageManager": {
			"name": "pnpm",
			"version": "11.13.1",
			"onFail": "error"
		}
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"tauri": "tauri"
	},
	"devDependencies": {
		"@iconify-json/lucide": "^1.2.117",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tauri-apps/cli": "^2.11.4",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^24.13.2",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "~6.0.2",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.1.1"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-global-shortcut": "^2.3.2",
		"dexie": "^4.4.4",
		"fractional-indexing": "^4.0.0",
		"pocketbase": "^0.27.0",
		"svelte-dnd-action": "^0.9.74"
	}
}
